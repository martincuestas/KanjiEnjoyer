# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# Local dev: SQLite. Production (Render + Neon): PostgreSQL connection string from Neon dashboard.
#   Neon format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=sqlite:///./kanji.db

# Comma-separated list of allowed frontend origins:
#   ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
